# nvmm replacement for Lambda CI (single-node, no GPU Operator).
#
# On Lambda, MIG cleanup is handled by e2e-test.sh on the host via SSH
# (where nvidia-smi is available). This stub accepts and discards the
# nvmm arguments so that cleanup-from-previous-run.sh does not fail.
#
# Usage (same as nvmm, but all commands are no-ops):
#   nvmm all sh -c 'nvidia-smi mig -dci; ...'

echo "nvmm (lambda): no-op — MIG managed by e2e-test.sh on the host"
exit 0
