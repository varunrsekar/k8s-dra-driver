apiVersion: v1
kind: Namespace
metadata:
  name: {{ .Namespace }}
---
apiVersion: resource.k8s.io/v1
kind: ResourceClaimTemplate
metadata:
  name: gpu-memory-template
  namespace: {{ .Namespace }}
spec:
  spec:
    devices:
      requests:
      - name: gpu
        exactly:
          count: 1
          deviceClassName: gpu.nvidia.com
          selectors:
          - cel:
              expression: device.capacity["gpu.nvidia.com"].memory.compareTo(quantity("{{ .RequiredMemoryGi }}Gi")) >= 0
---
apiVersion: v1
kind: Pod
metadata:
  name: test-gpu-memory
  namespace: {{ .Namespace }}
spec:
  restartPolicy: Never
  containers:
  - name: cuda-workload
    image: nvcr.io/nvidia/cuda:12.2.0-base-ubuntu22.04
    command: ["bash","-c"]
    args: ["nvidia-smi -L; nvidia-smi --query-gpu=memory.total --format=csv; trap 'exit 0' TERM; sleep 9999 & wait"]
    resources:
      claims:
      - name: gpu-claim
  resourceClaims:
  - name: gpu-claim
    resourceClaimTemplateName: gpu-memory-template
  tolerations:
  - key: "nvidia.com/gpu"
    operator: "Exists"
    effect: "NoSchedule"
